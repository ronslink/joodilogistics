---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us">
  <!-- Hero Section -->
  <section class="relative h-[614px] flex items-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img class="w-full h-full object-cover grayscale-[0.2]" data-alt="Modern logistics hub with automated sorting systems and fleet of trucks under dramatic evening sky with blue and orange tones" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA0BW3XYk6itPBrKq8wbokVI7bb_TuoX4Ccy4XTuCW6LC_9ej-wNJREpJtfGPU4N7EYLfnEE_eZGZnhk2c3AZvlpUUydAFcoiqMOkKz1Lxi59hD-EZ3r0tlYLFnww35G2DWzMl-hUKqf4FVpL0sPpQp47NCs4rMenpbtbGVNcbS0uo7bkxrrGO7KAoKiG4-Dp-QZTcb7aAHG1HWaOEp4-eY6X7IYdz_6LHFc_RIoZGZkg4Eif386u5T25SRBwpf74jtTDPBo2UyqnZg"/>
      <div class="absolute inset-0 bg-primary/40 mix-blend-multiply"></div>
    </div>
    <div class="container mx-auto px-8 relative z-10">
      <div class="max-w-4xl">
        <span class="inline-block bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded text-[0.75rem] font-bold tracking-widest uppercase mb-6">Established Logistics Excellence</span>
        <h1 class="text-white text-[3.5rem] leading-[1.1] font-extrabold tracking-tight mb-8">
          Architecting Global <br/>
          <span class="text-tertiary-fixed-dim">Trade Precision.</span>
        </h1>
      </div>
    </div>
  </section>
  <!-- Mission & Story Asymmetric Layout -->
  <section class="py-24 bg-surface">
    <div class="container mx-auto px-8">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-7">
          <h2 class="text-on-surface text-[1.75rem] font-bold mb-8">Our Mission</h2>
          <p class="text-on-surface-variant text-[1rem] leading-relaxed mb-6">
            At Joodi Logistics, we believe logistics is the circulatory system of the global economy. Our mission is to provide seamless, end-to-end supply chain solutions that transcend borders and operational complexities. 
          </p>
          <p class="text-on-surface-variant text-[1rem] leading-relaxed">
            We don't just move freight; we synchronize global commerce with an editorial eye for detail, ensuring that every shipment is a testament to our commitment to reliability and kinetic velocity.
          </p>
        </div>
        <div class="md:col-span-5 relative mt-12 md:mt-0">
          <div class="bg-surface-container-low p-8 editorial-shadow rounded-xl">
            <div class="space-y-12">
              <div class="flex items-start gap-4">
                <span class="material-symbols-outlined text-primary text-3xl" data-icon="precision_manufacturing">precision_manufacturing</span>
                <div>
                  <h3 class="font-bold text-primary mb-2">Precision</h3>
                  <p class="text-on-surface-variant text-sm">Every millimeter and millisecond accounted for in our orchestration.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <span class="material-symbols-outlined text-primary text-3xl" data-icon="verified_user">verified_user</span>
                <div>
                  <h3 class="font-bold text-primary mb-2">Reliability</h3>
                  <p class="text-on-surface-variant text-sm">Consistent delivery performance that builders trust.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <span class="material-symbols-outlined text-primary text-3xl" data-icon="security">security</span>
                <div>
                  <h3 class="font-bold text-primary mb-2">Safety</h3>
                  <p class="text-on-surface-variant text-sm">Rigorous protocols ensuring the integrity of every asset.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- CEO Profile Section (Bento Style) -->
  <section class="py-24 bg-surface-container-low">
    <div class="container mx-auto px-8">
      <div class="grid grid-cols-1 md:grid-cols-10 gap-8">
        <!-- Bio Content -->
        <div class="md:col-span-10 bg-surface-container-lowest p-12 rounded-xl editorial-shadow flex flex-col justify-center">
          <span class="text-primary text-[0.75rem] font-bold tracking-widest uppercase mb-4">Leadership</span>
          <h2 class="text-blue-950 text-[2.5rem] font-bold mb-6">John-Paul Odidika</h2>
          <p class="text-on-surface-variant italic mb-8 border-l-4 border-tertiary-fixed-dim pl-6 py-2">
            "Logistics is the art of solving problems before they manifest. We are building the future of global connectivity."
          </p>
          <div class="space-y-4 text-on-surface-variant leading-relaxed">
            <p>
              John-Paul Odidika serves as the visionary CEO of Joodi Logistics. With over two decades of experience in global trade orchestration and supply chain optimization, he has transformed Joodi into a powerhouse of precision logistics.
            </p>
            <p>
              Under his leadership, the company has expanded its footprint across three continents, integrating advanced tracking technologies with a human-centric approach to customer service. He remains committed to driving innovation through sustainable practices and technological agility.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- Global Network / Address -->
  <section class="py-24 bg-surface">
    <div class="container mx-auto px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-[1.75rem] font-bold mb-8">Our Headquarters</h2>
          <div class="bg-surface-container-high p-8 rounded-xl space-y-6">
            <div class="flex items-center gap-4">
              <span class="material-symbols-outlined text-primary" data-icon="location_on">location_on</span>
              <p class="text-on-surface font-semibold">Douglasienweg 1, 71364 Winnenden, Germany</p>
            </div>
            <div class="flex items-center gap-4">
              <span class="material-symbols-outlined text-primary" data-icon="mail">mail</span>
              <p class="text-on-surface">info@joodilogistics.com</p>
            </div>
            <div class="flex items-center gap-4">
              <span class="material-symbols-outlined text-primary" data-icon="public">public</span>
              <p class="text-on-surface">Global Network Hubs: Hamburg, Lagos, Dubai, Shanghai, Antwerp, Rotterdam, New York, Capetown, Mombasa</p>
            </div>
          </div>
        </div>
        <div class="h-[400px] bg-surface-container-highest rounded-xl overflow-hidden editorial-shadow">
          <img class="w-full h-full object-cover" data-alt="Abstract stylized map of Winnenden Germany with a minimalist navy and silver aesthetic showing Joodi Logistics headquarters location" data-location="Winnenden" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBLViXk7GIwOpnp5xO7aEUliDdBoju0I0c16jV7dm4esveCBgGL1g0FPV7R1XQAm2u55LrenEeb5aBwmpNUbK2ItgTuw_SliQuz9AbxkywYI2Paq6261CR8a0T_z-qgSdL0FpkiihkOemP8ZCq9Xi414_ChSHaGR049YXQPGcb0qjfuT2koTWlTAGZXvf3vbVQX3DxI4Wrj3FMSJKdONpptBC8y67lCU-PY-380KPtgNCxXkHFrTLExEHfKhXCfqXHif630BRNcW-4J"/>
        </div>
      </div>
    </div>
  </section>
</Layout>
