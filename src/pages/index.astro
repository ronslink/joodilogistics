---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="relative min-h-[921px] flex items-center overflow-hidden bg-surface">
    <div class="container mx-auto px-8 grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
      <div class="lg:col-span-7 z-10">
        <span class="text-tertiary font-label font-bold tracking-widest uppercase mb-4 block">Global Authority in Logistics</span>
        <h1 class="font-headline text-[3.5rem] leading-none font-extrabold text-primary editorial-text mb-6">
          Joodi International Logistics: <br/>Reliable &amp; Safe Logistics
        </h1>
        <p class="font-body text-xl text-on-surface-variant max-w-xl mb-10 leading-relaxed">
          Orchestrating Global Trade with Precision Velocity. Experience a high-end logistics partner that balances technical excellence with authoritative reliability.
        </p>
        <div class="flex flex-wrap gap-4">
          <button class="primary-gradient text-on-primary px-8 py-4 rounded-md font-bold shadow-xl flex items-center gap-2 group transition-all">
            Request Information
            <span class="material-symbols-outlined text-xl group-hover:translate-x-1 transition-transform" data-icon="arrow_forward">arrow_forward</span>
          </button>
          <a href="/contact" class="bg-surface-container-highest text-primary px-8 py-4 rounded-md font-bold hover:bg-surface-container-high transition-colors text-center inline-block">
            Contact Us
          </a>
        </div>
      </div>
      <div class="lg:col-span-5 relative">
        <div class="aspect-square rounded-full overflow-hidden shadow-2xl relative">
          <img alt="Global Logistics Network" class="w-full h-full object-cover" data-alt="Dynamic modern logistics composition featuring a cargo airplane, container ship, freight train, and delivery van blending together in cinematic blue hour lighting" src="/multimodal_logistics.png"/>
          <div class="absolute inset-0 bg-primary/20 mix-blend-multiply"></div>
        </div>
        <!-- Floating Data Card -->
        <div class="absolute -bottom-8 -left-8 bg-surface-container-lowest p-6 rounded-xl shadow-[0_20px_40px_rgba(25,28,30,0.06)] max-w-[240px]">
          <div class="flex items-center gap-3 mb-2">
            <span class="material-symbols-outlined text-on-tertiary-container" data-icon="monitoring">monitoring</span>
            <span class="text-xs font-label uppercase tracking-widest font-bold">Real-time status</span>
          </div>
          <div class="h-2 w-full bg-surface-container-high rounded-full overflow-hidden">
            <div class="h-full bg-tertiary-fixed-dim w-3/4"></div>
          </div>
          <p class="text-[10px] text-on-surface-variant mt-2">Active shipments across 140+ countries monitored 24/7.</p>
        </div>
      </div>
    </div>
  </section>
  <!-- Services Section - Bento Grid Layout -->
  <section class="py-24 bg-surface-container-low">
    <div class="container mx-auto px-8">
      <div class="mb-16">
        <h2 class="font-headline text-3xl font-bold text-primary mb-4">Core Competencies</h2>
        <p class="text-on-surface-variant font-body max-w-2xl">End-to-end orchestration of global logistics cycles, delivered with surgical precision and strategic insight.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Service 1: Large Feature -->
        <div class="md:col-span-2 bg-surface-container-lowest p-8 rounded-xl flex flex-col justify-between group hover:bg-primary transition-colors duration-500 overflow-hidden relative">
          <div class="relative z-10">
            <span class="material-symbols-outlined text-4xl text-on-primary-container group-hover:text-tertiary-fixed-dim mb-6" data-icon="local_shipping">local_shipping</span>
            <h3 class="text-2xl font-bold text-primary group-hover:text-white mb-4">Transport Management</h3>
            <p class="text-on-surface-variant group-hover:text-blue-100 max-w-md">Seamless coordination of air, sea, and land assets to ensure your cargo moves through the global network without friction.</p>
          </div>
          <img class="absolute right-0 bottom-0 w-1/3 opacity-10 group-hover:opacity-20 transition-opacity" data-alt="A detailed blueprint of a logistics network with interconnected lines and points on a clean dark background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCJNzeajk9w28-in-5Pj3h59SGma_pBtasdb4AnvnlFMWxiTf88e4dfr-g70qdfabU-c3ekScke8P52K9UKG5WQRHk-j-Le6-pYvctPsG_U2KSmKZ-XMTBqcCF620Lkx1Dn2nHFt6XltyvhyIwVKnWPdz83MalwPC0xkld65NWvSPFHJrLX0sv3A6WuIJh5EnYaUADlnipclNEPrx2j5m-EgtLrMBzjigkjZPbj3hK7G6eV4rMY6QrkQZr6QIvat6A0aLBPrKAYbyIk"/>
        </div>
        <!-- Service 2 -->
        <div class="bg-surface-container-lowest p-8 rounded-xl hover:shadow-xl transition-all">
          <span class="material-symbols-outlined text-3xl text-on-primary-container mb-6" data-icon="inventory_2">inventory_2</span>
          <h3 class="text-xl font-bold text-primary mb-2">Goods Distribution</h3>
          <p class="text-sm text-on-surface-variant mb-4">Strategic last-mile delivery and localized warehousing solutions for rapid market penetration.</p>
          <a class="text-primary font-bold text-xs uppercase tracking-wider flex items-center gap-1 group" href="/services">
            Explore <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform" data-icon="chevron_right">chevron_right</span>
          </a>
        </div>
        <!-- Service 3 -->
        <div class="bg-surface-container-lowest p-8 rounded-xl hover:shadow-xl transition-all">
          <span class="material-symbols-outlined text-3xl text-on-primary-container mb-6" data-icon="language">language</span>
          <h3 class="text-xl font-bold text-primary mb-2">Import &amp; Export</h3>
          <p class="text-sm text-on-surface-variant mb-4">Navigating complex customs regulations and international trade laws with absolute compliance.</p>
        </div>
        <!-- Service 4 -->
        <div class="bg-surface-container-lowest p-8 rounded-xl hover:shadow-xl transition-all">
          <span class="material-symbols-outlined text-3xl text-on-primary-container mb-6" data-icon="campaign">campaign</span>
          <h3 class="text-xl font-bold text-primary mb-2">Marketing Services</h3>
          <p class="text-sm text-on-surface-variant mb-4">Supporting your brand's growth through integrated logistics-driven promotional distribution.</p>
        </div>
        <!-- Service 5 -->
        <div class="bg-surface-container-lowest p-8 rounded-xl hover:shadow-xl transition-all">
          <span class="material-symbols-outlined text-3xl text-on-primary-container mb-6" data-icon="delete_sweep">delete_sweep</span>
          <h3 class="text-xl font-bold text-primary mb-2">Waste Management</h3>
          <p class="text-sm text-on-surface-variant mb-4">Specialized logistics for industrial waste and recycling, adhering to highest environmental standards.</p>
        </div>
        <!-- Service 6 -->
        <div class="bg-surface-container-lowest p-8 rounded-xl hover:shadow-xl transition-all">
          <span class="material-symbols-outlined text-3xl text-on-primary-container mb-6" data-icon="home_storage">home_storage</span>
          <h3 class="text-xl font-bold text-primary mb-2">Relocation Transport</h3>
          <p class="text-sm text-on-surface-variant mb-4">Premium relocation services for corporate entities and high-value domestic assets.</p>
        </div>
      </div>
    </div>
  </section>
  <!-- Dynamic Visual Split Section -->
  <section class="py-24 overflow-hidden">
    <div class="container mx-auto px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
        <div class="relative">
          <div class="absolute -top-12 -left-12 w-64 h-64 bg-secondary-container/30 rounded-full blur-3xl"></div>
          <img class="rounded-xl shadow-2xl relative z-10" data-alt="Close-up of a high-tech logistics tracking terminal showing global route lines on a dark glass screen" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAcajEutPf0BlYG0F4fnAjAOTcUVffwY2XoAHba_O8RXNRgvvIibM7FsUog74UuzcrFiJygzduJo-eVc0Lq8dGEzblJ-3RWWvk6U0OD-fZoy--SiUaUSIOrdeZLtWefhfUSt2oOeDsiQJcYaMs_KwiAvylPgHCdjBVL7uxsUoeYceSvMKEhUpqVWmw7kc7C78t1kHB0TdsB2Y2aaXlZ5P3yN9K0EX51UFXpqKgERIixZsHbIJTcGaP4D3gr4alJhw7Nkuf8rFGe-kf2"/>
        </div>
        <div>
          <h2 class="font-headline text-3xl font-bold text-primary mb-6">Efficiency Redefined</h2>
          <div class="space-y-8">
            <div class="flex gap-4">
              <div class="w-12 h-12 rounded-full bg-primary-fixed-dim flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-primary" data-icon="speed">speed</span>
              </div>
              <div>
                <h4 class="font-bold text-primary mb-1">Precision Velocity</h4>
                <p class="text-sm text-on-surface-variant">We don't just move things; we optimize the entire kinetic chain of your supply operation.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-12 h-12 rounded-full bg-secondary-container flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-on-secondary-container" data-icon="shield">shield</span>
              </div>
              <div>
                <h4 class="font-bold text-primary mb-1">Uncompromising Safety</h4>
                <p class="text-sm text-on-surface-variant">Rigorous protocols ensure every shipment, from waste to high-value goods, arrives exactly as intended.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
