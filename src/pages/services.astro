---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Services">
  <!-- Hero Section -->
  <section class="relative px-8 md:px-16 py-20 overflow-hidden">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7 z-10">
        <span class="inline-block px-3 py-1 bg-secondary-container text-on-secondary-container text-[10px] uppercase tracking-[0.2em] font-bold rounded-full mb-6">Our Expertise</span>
        <h1 class="text-5xl md:text-7xl font-extrabold text-primary leading-[1.1] tracking-tight mb-8">
          Global Trade <br/><span class="text-on-primary-container">Architected.</span>
        </h1>
        <p class="text-lg text-on-surface-variant max-w-xl leading-relaxed mb-10">
          From intricate transport management to international market representation, we provide the kinetic infrastructure for modern global logistics.
        </p>
      </div>
      <div class="lg:col-span-5 relative">
        <div class="aspect-square bg-surface-container rounded-3xl overflow-hidden relative">
          <img class="w-full h-full object-cover grayscale-[0.5] contrast-[1.1]" data-alt="Modern logistics warehouse with automated shelving systems and blue industrial lighting, sharp focus, cinematic corporate photography" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDezPT-CJM0okpgqOx9ZabpvKsa5qUxI9yBndAYxu_2RSSMtDsm2Hw55D4sc3UQ33sHmJYXRihWhWnE-bt7It6Nj41AWmNROk73QKXl7O5Ng7c9pwsokcBnX7FbpvD_Y3uPlmr8SiNv_HM0WJ77o0M0L9vz4dlrKtPZ_yoQpw54e2ciMV8ArjeBLsxiV_XMHiC_6x6eTEJUhdJowU6YBB7eYfyVbedA_pje-_SKwA8Qfx_LWvbmQf3jUM43eG1sDDLhWXgoYCeWb1W5"/>
          <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-transparent"></div>
        </div>
        <!-- Asymmetric floating element -->
        <div class="absolute -bottom-8 -left-8 bg-surface-container-lowest p-8 rounded-2xl editorial-shadow max-w-[240px] border border-outline-variant/15">
          <div class="flex items-center gap-3 mb-2">
            <span class="material-symbols-outlined text-tertiary-fixed-dim" style="font-variation-settings: 'FILL' 1;">bolt</span>
            <span class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Efficiency</span>
          </div>
          <p class="text-sm font-medium text-on-surface italic">"Precision at every node of the supply chain."</p>
        </div>
      </div>
    </div>
  </section>
  <!-- Services Bento Grid -->
  <section class="px-8 md:px-16 py-12 bg-surface-container-low">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- 1. Transport Management -->
        <div class="md:col-span-2 bg-surface-container-lowest p-10 rounded-3xl flex flex-col justify-between group hover:bg-primary transition-colors duration-500">
          <div>
            <span class="material-symbols-outlined text-4xl mb-8 group-hover:text-white transition-colors" data-icon="local_shipping">local_shipping</span>
            <h3 class="text-3xl font-bold mb-4 group-hover:text-white transition-colors">Transport Management</h3>
            <p class="text-on-surface-variant group-hover:text-white/80 transition-colors leading-relaxed max-w-xl">
              We orchestrate complex multimodal transport networks with tactical precision. Our systems integrate real-time tracking with dynamic route optimization to ensure your assets are always in motion.
            </p>
          </div>
          <div class="mt-8 flex gap-2">
            <span class="px-3 py-1 rounded-full bg-surface-container text-[10px] font-bold text-on-surface-variant uppercase">Air</span>
            <span class="px-3 py-1 rounded-full bg-surface-container text-[10px] font-bold text-on-surface-variant uppercase">Sea</span>
            <span class="px-3 py-1 rounded-full bg-surface-container text-[10px] font-bold text-on-surface-variant uppercase">Land</span>
          </div>
        </div>
        <!-- 2. Goods Distribution -->
        <div class="bg-surface-container-highest p-10 rounded-3xl flex flex-col relative overflow-hidden">
          <div class="z-10">
            <span class="material-symbols-outlined text-4xl mb-8 text-primary" data-icon="inventory_2">inventory_2</span>
            <h3 class="text-2xl font-bold mb-4">Goods Distribution</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">
              Last-mile excellence through localized hubs. Our distribution networks are designed to minimize latency and maximize touchpoint efficiency.
            </p>
          </div>
          <div class="mt-auto pt-8">
            <img class="w-full h-32 object-cover rounded-xl opacity-60" data-alt="Close up of cardboard packages moving on a conveyor belt in a clean modern logistics facility, soft bokeh background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCttK9JAWI_TPfs_GT4TmCMHRs8vgVxWiOnPUrFbuasoDfYX_V78obwYX4Xvyn_3wE7t_oBKDkI-oLCbgvICSgOrdkjGssB9mi6jvQod6mcuy3bAzMRtVL_UhgSiMfQglQ8qlj0zePMbnBZb29NrAJiQiJl8JZS_ZGVRCYPdm7ydsIh21RYrORfWeAPgUyO7RO0fppcZJtMvxTWO5lXRFAcsyP7q6RPshZh2k3sJcdcVxEBpmIzO5nYUxR1JRczof93N6Hstsl-7jS5"/>
          </div>
        </div>
        <!-- 3. Import & Export -->
        <div class="bg-surface-container-lowest p-10 rounded-3xl border border-outline-variant/10">
          <span class="material-symbols-outlined text-4xl mb-8 text-primary" data-icon="language">language</span>
          <h3 class="text-2xl font-bold mb-4">Import &amp; Export</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed mb-6">
            Bridging consumer and industrial sectors. We handle the complex regulatory landscape of global trade, from customs brokerage to compliance auditing.
          </p>
          <div class="flex items-center text-primary font-bold text-xs uppercase tracking-widest gap-2">
            Global Compliance <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </div>
        </div>
        <!-- 4. Marketing Services -->
        <div class="bg-primary text-on-primary p-10 rounded-3xl md:col-span-2 relative overflow-hidden">
          <div class="relative z-10 grid md:grid-cols-2 gap-8 items-center">
            <div>
              <span class="material-symbols-outlined text-4xl mb-8 text-tertiary-fixed-dim" data-icon="campaign">campaign</span>
              <h3 class="text-3xl font-bold mb-4">Marketing &amp; Representation</h3>
              <p class="text-white/70 leading-relaxed">
                Strategic brand positioning for international players. We provide professional representation and localized marketing services to ensure your products resonate in new territories.
              </p>
            </div>
            <div class="hidden md:block">
              <div class="p-6 bg-white/5 rounded-2xl backdrop-blur-sm border border-white/10">
                <div class="h-2 w-full bg-white/10 rounded-full mb-4">
                  <div class="h-full w-3/4 bg-tertiary-fixed-dim rounded-full"></div>
                </div>
                <div class="h-2 w-full bg-white/10 rounded-full mb-4">
                  <div class="h-full w-1/2 bg-white/40 rounded-full"></div>
                </div>
                <p class="text-[10px] uppercase font-bold tracking-widest opacity-60">Market Penetration Index</p>
              </div>
            </div>
          </div>
        </div>
        <!-- 5. Waste Management -->
        <div class="bg-surface-container-highest p-10 rounded-3xl">
          <span class="material-symbols-outlined text-4xl mb-8 text-primary" data-icon="recycling">recycling</span>
          <h3 class="text-2xl font-bold mb-4">Waste Management</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">
            Sustainable lifecycle logistics. We offer comprehensive waste removal and processing solutions focused on environmental responsibility and regulatory adherence.
          </p>
        </div>
        <!-- 6. Relocation Transport -->
        <div class="md:col-span-2 bg-surface-container-lowest p-10 rounded-3xl flex flex-col md:flex-row gap-8 items-center border border-outline-variant/10">
          <div class="flex-1">
            <span class="material-symbols-outlined text-4xl mb-8 text-primary" data-icon="home_storage">home_storage</span>
            <h3 class="text-2xl font-bold mb-4">Relocation Transport</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">
              Precision moving for corporate and industrial assets. Our specialized teams manage delicate relocations with zero-downtime objectives and white-glove handling.
            </p>
          </div>
          <div class="w-full md:w-64 aspect-video rounded-2xl overflow-hidden bg-surface-container">
            <img class="w-full h-full object-cover" data-alt="Interior of a clean modern industrial building with high ceilings and bright natural light, professional relocation setup" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA7iBxDjSc57uxxLzNCF6XwpiQUMzf1Cpw0ADBWivh8BEgkbU3Yaj6uLQiD9oX0AaoQJN-8UCnK-ASWSVTAmqWYYibp7T7HWFrW5-jRpeK9CJS4OZGadU7vTx1XhkGTXhi6fu_VRoeAVOjseVhj3TbMkLW7_Wrb3L1lumkIYgpCITf8Lc95Jkw87xtfsUuFVke8XFGsN6Ig6hYD-_yHxptqPtLaWFNqDZEfYEKmyr2ECf9eRgj4ksnk1LTZxaTlXuhuxhOAE_fE14at"/>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- CTA Section -->
  <section class="px-8 md:px-16 py-24 bg-surface-container">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl font-extrabold text-primary mb-6">Ready to Optimize Your Chain?</h2>
      <p class="text-on-surface-variant mb-10 max-w-2xl mx-auto">
        Speak with our logistics consultants today to design a bespoke strategy for your global operations.
      </p>
      <div class="flex flex-col md:flex-row gap-4 justify-center">
        <button class="bg-tertiary-fixed-dim text-on-tertiary-fixed px-8 py-4 rounded-lg font-bold hover:scale-105 transition-transform">Book a Consultation</button>
        <button class="bg-surface-container-lowest text-primary px-8 py-4 rounded-lg font-bold hover:bg-surface-container-high transition-colors">Our Global Network</button>
      </div>
    </div>
  </section>
</Layout>
